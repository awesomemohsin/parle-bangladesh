# =========================================================================
# PARLE BANGLADESH ENVIRONMENT CONFIGURATIONS TEMPLATE (.env.example)
# =========================================================================
# Duplicate this file as '.env.local' for local development overrides.
# Configure these variables in your hosting provider (e.g. Vercel dashboard)
# for live production deployment.
# =========================================================================

# Database Connection
MONGODB_URI="your_mongodb_connection_string"
JWT_SECRET="your_jwt_secret_token"
BLOB_READ_WRITE_TOKEN="your_vercel_blob_rw_token"

# SMTP Configuration (e.g., Brevo)
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT=587
SMTP_USER="your_smtp_username"
SMTP_PASSWORD="your_smtp_password"
SMTP_SECURE=false
SMTP_FROM_EMAIL="info.parlebangladesh@gmail.com"
SMTP_TO_EMAIL="cfb@circlenetworkbd.net"

# Application Settings
NEXT_PUBLIC_APP_URL="https://parlebangladesh.com"

# Telegram Bot configuration (For administrative/logistics alert feeds)
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"
TELEGRAM_CHAT_ID_MANAGEMENT="your_management_chat_id"
TELEGRAM_CHAT_ID_LOGISTICS="your_logistics_chat_id"
TELEGRAM_OWNER_IDS="comma_separated_owner_user_ids"

# SSLCommerz Payment Gateway Configuration
NEXT_PUBLIC_ENABLE_SSLCOMMERZ=false
SSLCOMMERZ_STORE_ID="your_sslcommerz_store_id"
SSLCOMMERZ_STORE_PASSWORD="your_sslcommerz_password"
SSLCOMMERZ_IS_SANDBOX=true

# Initial Admin & Owner Setup Credentials (for /api/owner-setup)
INITIAL_OWNER_EMAIL="owner@parle.com"
INITIAL_OWNER_PASSWORD="owner_setup_password"
INITIAL_ADMIN_EMAIL="admin@parle.com"
INITIAL_ADMIN_PASSWORD="admin_setup_password"

# Meta Ads tracking Configuration
NEXT_PUBLIC_META_PIXEL_ID="your_meta_pixel_id"

# Secure Catalog Feed Secret Key
FEED_SECRET_KEY="your_secure_feed_secret_key"

# Steadfast Courier Integration Configurations
NEXT_PUBLIC_STEADFAST_ENABLED="true"
STEADFAST_API_URL="https://portal.packzy.com/api/v1"
STEADFAST_API_KEY="your_steadfast_api_key"
STEADFAST_SECRET_KEY="your_steadfast_secret_key"
STEADFAST_WEBHOOK_TOKEN="your_steadfast_webhook_secret_token"
